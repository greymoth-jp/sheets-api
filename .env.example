# ─── Database (Turso) ─────────────────────────────────────────────────────────
TURSO_DATABASE_URL=libsql://your-db.turso.io
TURSO_AUTH_TOKEN=

# ─── Better Auth ──────────────────────────────────────────────────────────────
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3040
NEXT_PUBLIC_APP_URL=http://localhost:3040

# ─── Google OAuth (Sheets + Drive scopes) ─────────────────────────────────────
# GCP Console → APIs & Services → Credentials → OAuth 2.0 Client ID
# Authorized redirect URIs: http://localhost:3040/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Required for Google One Tap (FedCM)
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# ─── Apple Sign-In (optional) ─────────────────────────────────────────────────
# APPLE_CLIENT_ID=
# APPLE_TEAM_ID=
# APPLE_KEY_ID=
# APPLE_PRIVATE_KEY=

# ─── Email (Resend) ───────────────────────────────────────────────────────────
RESEND_API_KEY=

# ─── Stripe ───────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_
STRIPE_WEBHOOK_SECRET=whsec_
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_

# Price IDs — create in Stripe Dashboard → Products
STRIPE_PRICE_STARTER_MONTHLY=price_
STRIPE_PRICE_STARTER_YEARLY=price_
STRIPE_PRICE_DEV_MONTHLY=price_
STRIPE_PRICE_DEV_YEARLY=price_
STRIPE_PRICE_TEAM_MONTHLY=price_
STRIPE_PRICE_TEAM_YEARLY=price_
STRIPE_PRICE_FOUNDING=price_

# Also expose for client-side Settings upgrade buttons
NEXT_PUBLIC_STRIPE_PRICE_STARTER_MONTHLY=price_
NEXT_PUBLIC_STRIPE_PRICE_STARTER_YEARLY=price_
NEXT_PUBLIC_STRIPE_PRICE_DEV_MONTHLY=price_
NEXT_PUBLIC_STRIPE_PRICE_DEV_YEARLY=price_
NEXT_PUBLIC_STRIPE_PRICE_TEAM_MONTHLY=price_
NEXT_PUBLIC_STRIPE_PRICE_TEAM_YEARLY=price_

# ─── Upstash Redis (rate limit + cache) ───────────────────────────────────────
# console.upstash.com → Create Database → REST API
# Free tier: 10K commands/day (upgrade when live traffic exceeds this)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ─── PostHog (Analytics) ──────────────────────────────────────────────────────
NEXT_PUBLIC_POSTHOG_KEY=phc_
POSTHOG_HOST=https://us.i.posthog.com

# ─── Sentry (Error Monitoring) ────────────────────────────────────────────────
NEXT_PUBLIC_SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
SENTRY_AUTH_TOKEN=sntrys_
SENTRY_ORG=
SENTRY_PROJECT=sheets-api
